# ── Twenty server & worker ─────────────────────────────────
# Postgres credentials live in .env.postgres (db container).
# DB DSN — host "db"; user/password/db must match .env.postgres
PG_DATABASE_URL=postgres://postgres:CHANGE_ME@db:5432/default
REDIS_URL=redis://redis:6379

# Public URL Twenty is served from (used for links, CORS, auth callbacks)
SERVER_URL=https://twenty.example.com

# Secrets — generate each with: openssl rand -base64 32
# Losing ENCRYPTION_KEY means losing access to every secret in the DB.
ENCRYPTION_KEY=
APP_SECRET=
# Optional: set the previous ENCRYPTION_KEY here during key rotation
FALLBACK_ENCRYPTION_KEY=

# Storage backend: local (default) or s3
STORAGE_TYPE=local
# STORAGE_S3_REGION=
# STORAGE_S3_NAME=
# STORAGE_S3_ENDPOINT=

# ── Email (optional) ───────────────────────────────────────
# EMAIL_FROM_ADDRESS=contact@yourdomain.com
# EMAIL_FROM_NAME=John from YourDomain
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# ── Google OAuth / sync (optional) ─────────────────────────
# MESSAGING_PROVIDER_GMAIL_ENABLED=true
# CALENDAR_PROVIDER_GOOGLE_ENABLED=true
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=
# AUTH_GOOGLE_APIS_CALLBACK_URL=

# ── Microsoft OAuth / sync (optional) ──────────────────────
# CALENDAR_PROVIDER_MICROSOFT_ENABLED=true
# MESSAGING_PROVIDER_MICROSOFT_ENABLED=true
# AUTH_MICROSOFT_ENABLED=true
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_CALLBACK_URL=
# AUTH_MICROSOFT_APIS_CALLBACK_URL=
