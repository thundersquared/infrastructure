# Copy this file to backend.s3.tfvars and fill in your values.
# backend.s3.tfvars is gitignored — never commit it.
#
# Usage: tofu init -backend-config=backend.s3.tfvars

bucket     = "infrastructure-state"
key        = "tower/terraform.tfstate"
region     = "eu-frankfurt-1"
endpoint   = "https://<namespace>.compat.objectstorage.eu-frankfurt-1.oraclecloud.com"
access_key = "..."
secret_key = "..."

skip_region_validation      = true
skip_credentials_validation = true
skip_metadata_api_check     = true
force_path_style            = true
