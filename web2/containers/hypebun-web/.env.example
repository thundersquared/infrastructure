# MariaDB credentials for the hypebun-web stack.
# Copy to .env and fill with real secrets (never commit .env).
MYSQL_ROOT_PASSWORD=
# Database created on first boot (production). Create the test database manually
# (see README.md): hypebun_bio_test.
MYSQL_DATABASE=hypebun_bio_prod
MYSQL_USER=
MYSQL_PASSWORD=

# On-demand TLS authorization (self-served domains). Public IP(s) of this host,
# comma-separated, used to verify a custom domain points here before issuing a
# cert. Set HYPEBUN_TLS_VERIFY_DNS=0 to skip the DNS check.
HYPEBUN_SERVER_IPS=
HYPEBUN_TLS_VERIFY_DNS=1
