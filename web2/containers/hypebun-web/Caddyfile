### Hypebun (FrankenPHP) — Caddy global options
### Docs: https://caddyserver.com/docs/caddyfile/options
{
	email help@hypebun.com

	# Self-served domains: users point their own domain at this server and Caddy
	# obtains a Let's Encrypt certificate on demand. The "ask" endpoint gates which
	# hostnames are allowed a certificate (returns HTTP 200 to allow). It is served
	# locally by this same FrankenPHP instance (see the :9180 block below), so there
	# is no external dependency on the cert hot path.
	on_demand_tls {
		ask http://127.0.0.1:9180/can-generate-https.php
	}
}

### Internal on-demand TLS authorization endpoint (loopback only).
# Caddy queries this before issuing a certificate for an unknown host. It runs
# the prod release's tools/can-generate-https.php, which checks the `domains`
# table. Plain HTTP on loopback => no TLS recursion, no external calls.
http://127.0.0.1:9180 {
	root * /app/prod/current
	rewrite * /tools/can-generate-https.php?{query}
	php_server
}

### Production
# Docroot is the "current" symlink of the release tree; deploy.sh flips it
# atomically for zero-downtime deploys.
bio.hypebun.com {
	root * /app/prod/current
	try_files {path} /index.php?{query}&altum={path}
	php_server
}

### Test
bio-test.hypebun.com {
	root * /app/test/current
	try_files {path} /index.php?{query}&altum={path}
	php_server
}

### User custom domains (self-served) — served by the production app.
### Any hostname not matched above hits this block; on-demand TLS issues a cert
### after the "ask" endpoint approves it.
https:// {
	tls {
		on_demand
	}

	root * /app/prod/current
	try_files {path} /index.php?{query}&altum={path}
	php_server
}
