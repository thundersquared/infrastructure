[mysqld]
# Write the socket into the shared db_socket volume (/run/mysqld) so the
# FrankenPHP container can reach the DB over a UNIX socket (zero-TCP).
socket = /run/mysqld/mysqld.sock

character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

[client]
socket = /run/mysqld/mysqld.sock
default-character-set = utf8mb4
