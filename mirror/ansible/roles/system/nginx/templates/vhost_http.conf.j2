server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_hostname }};

    location /.well-known/acme-challenge/ {
        root {{ nginx_certbot_webroot }};
    }

    root {{ nginx_media_root }};
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    location / {
        try_files $uri $uri/ =404;
    }
}
