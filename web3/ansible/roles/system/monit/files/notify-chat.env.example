# Monit chat notifier credentials.
# Deployed to /etc/monit/notify-chat.env ONLY IF ABSENT (force: no), so your
# hand-edited secrets survive Ansible re-runs. Fill the channels you want;
# leave the rest blank to disable them. Keep this file mode 0600.

# --- Telegram ---
# 1. Create a bot via @BotFather -> get the token.
# 2. Get your chat id (e.g. message @userinfobot, or use getUpdates).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Slack ---
# Create an Incoming Webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
