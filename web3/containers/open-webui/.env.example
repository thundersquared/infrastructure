# Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=changeme

# Restrict CORS (default: * — must lock down in production)
CORS_ALLOW_ORIGIN=https://ai.example.com

# Public URL (required for OAuth redirects)
WEBUI_URL=https://ai.example.com

# JWT expiry — never set to -1 (disables expiration entirely)
JWT_EXPIRES_IN=4w

# Generic OIDC / SSO (e.g. Authentik)
ENABLE_OAUTH_SIGNUP=false
ENABLE_PASSWORD_AUTH=true
OAUTH_PROVIDER_NAME=Authentik
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OPENID_PROVIDER_URL=https://auth.example.com/application/o/<slug>/
OAUTH_SCOPES=openid email profile
OAUTH_USERNAME_CLAIM=name
OAUTH_EMAIL_CLAIM=email
